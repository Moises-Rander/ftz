# =============================================================================
# FTZ — variáveis de ambiente (copie para .env e ajuste os valores)
# NUNCA versione o arquivo .env com valores reais.
# =============================================================================

# --- Django ---
# Gere uma chave nova em produção (ex.: python -c "import secrets;print(secrets.token_urlsafe(50))")
SECRET_KEY=troque-esta-chave-em-producao
DEBUG=True
# Lista separada por vírgula (ex.: api.ftzait.com.br). Vazio em dev.
ALLOWED_HOSTS=

# --- Banco de dados ---
# Em produção, o Render injeta DATABASE_URL (Postgres). Em dev, se vazio, usa SQLite.
# DATABASE_URL=postgres://user:senha@host:5432/ftz

# Origens confiáveis para o Admin (CSRF) sob HTTPS. Ex.: https://api.ftzait.com.br,https://ftzait.com.br
CSRF_TRUSTED_ORIGINS=

# URLs base usadas nos links dos emails
FRONTEND_URL=http://localhost:5173
BACKEND_URL=http://localhost:8000

# Origens permitidas para CORS (front-end). Lista separada por vírgula.
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# --- Email / SMTP ---
# Em desenvolvimento, use o backend de console (imprime o email no terminal):
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
# Em produção, use o backend SMTP nativo do Django:
# EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.seuprovedor.com
EMAIL_PORT=587
EMAIL_HOST_USER=zenaldooliveira67@gmail.com
EMAIL_HOST_PASSWORD=sua-senha-ou-app-password
EMAIL_USE_TLS=True
# Nome exibido no campo "De":
DEFAULT_FROM_EMAIL=Faculdade de Teologia Zait <zenaldooliveira67@gmail.com>
# Endereço do Admin que recebe notificações internas (matrículas a validar, etc.):
ADMIN_EMAIL=zenaldooliveira67@gmail.com

# --- Dados institucionais (cabeçalho/rodapé dos emails) ---
FTZ_NOME=Faculdade de Teologia Zait
FTZ_CONTATO_EMAIL=zenaldooliveira67@gmail.com
FTZ_CONTATO_TELEFONE=(98) 98833-9224
# URL pública do logo (opcional); se vazio, exibe o nome como placeholder:
FTZ_LOGO_URL=

# --- Asaas (pagamentos) ---
# ASAAS_FAKE=True usa um cliente simulado (sem rede), ideal para dev/testes.
# Em produção: ASAAS_FAKE=False e ASAAS_BASE_URL=https://api.asaas.com/v3
ASAAS_FAKE=True
ASAAS_API_KEY=
ASAAS_BASE_URL=https://sandbox.asaas.com/api/v3
ASAAS_WEBHOOK_TOKEN=troque-este-token-do-webhook

# --- Storage de mídia (produção) ---
# USE_S3=True guarda uploads em buckets S3-compatíveis (ex.: Cloudflare R2).
# Use DOIS buckets: um PÚBLICO (imagens) e um PRIVADO (documentos sensíveis).
USE_S3=False
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_STORAGE_BUCKET_NAME=ftz-media   # bucket PÚBLICO (imagens)
AWS_PRIVATE_BUCKET_NAME=ftz-docs    # bucket PRIVADO (RG/CPF/histórico)
# Endpoint do R2 (ex.: https://<accountid>.r2.cloudflarestorage.com) ou vazio p/ AWS S3
AWS_S3_ENDPOINT_URL=
# Domínio público SÓ do bucket de imagens (ex.: cdn.ftzait.com.br ou pub-xxxx.r2.dev)
AWS_S3_CUSTOM_DOMAIN=

# --- Segurança / Observabilidade (produção) ---
# SECURE_SSL_REDIRECT=True   # já é o padrão quando DEBUG=False
SENTRY_DSN=
# Limites de tentativas (anti brute-force)
THROTTLE_LOGIN=10/min
THROTTLE_PASSWORD_RESET=5/min
